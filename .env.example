# ZeroVault Environment Variables
# Copy this file to .env.local and fill in your Supabase credentials

NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Supabase service role key (for cron API - admin access)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Cron endpoint authentication
CRON_SECRET=your_cron_secret_here

# Brevo (brevo.com) transactional email API key
BREVO_API_KEY=your_brevo_api_key_here
BREVO_SENDER_EMAIL=zerovaultstorage@gmail.com
